// Optimized - HashSet, while loop
class Solution {
    public boolean isHappy(int n) {
        Set<Integer> seen=new HashSet<>();
        while(true)
        {
            if(n==1)
                return true;
            if(!seen.add(n))
                return false;
            int sum=0;
            while(n>0)
            {
                sum+=((n%10)*(n%10));
                n/=10;
            }
            n=sum;
        }
    }
}
