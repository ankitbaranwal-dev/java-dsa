class Solution {
    public boolean isValid(String s) {
        if(s.length()%2!=0)
            return false;
        Stack<Character> stk=new Stack<>();
        for(int i=0; i<s.length(); i++)
        {
            char ch=s.charAt(i);
            if((ch==')' && (stk.isEmpty() || stk.pop()!='(')) || (ch=='}' && (stk.isEmpty() || stk.pop()!='{')) || (ch==']' && (stk.isEmpty() || stk.pop()!='[')))
                return false;
            else if((ch=='(') || (ch=='{') || (ch=='['))
                stk.push(ch);
        }
        return stk.isEmpty();
    }
}
